# Copier ce fichier en .env.local (ne jamais commiter les secrets).

# Region Lovers — login + référentiel SIT (fact checking, place-instance-drafts)
API_REGION_LOVERS=
# Cluster SIT pour l'autocomplétion POI (défaut : recVzMydIlyUoBvvB)
# SIT_CLUSTER_ID=recVzMydIlyUoBvvB

# OpenAI — réponse initiale + extraction des faits (défaut: gpt-5-mini)
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-5-mini

# Perplexity Sonar — vérification factuelle
PERPLEXITY_API_KEY=

# Apify — collecte posts Facebook (veille réseaux sociaux)
APIFY_API_TOKEN=
# Veille sociale — POI du cluster (défaut sans variable : 2 POI démo MUMA + restaurant)
# SOCIAL_WATCH_POI_IDS=museum_6e67acc1-1f88-4e85-8b46-191b8c20302c,restaurant_bar_cafe_f53c0564-7b5e-4a8d-b3ef-a4cd2913ea35
# SOCIAL_WATCH_POI_IDS=all

# Vision — classification d'images (défaut: gpt-4o)
# OPENAI_VISION_MODEL=gpt-4o

# MongoDB — index visuel SigLIP (doublons)
# Local : docker compose up mongo
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=demonstrator

# SigLIP — service Python (services/siglip-embed, port 8001)
SIGLIP_SERVICE_URL=http://localhost:8001
# SIGLIP_MOCK=true
# SIMILARITY_MIN_SCORE=0.82
